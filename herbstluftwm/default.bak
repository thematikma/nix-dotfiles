#!/usr/bin/env bash
# Generate Events, so the panel will be dynamically populated. Called in panel.sh.
#
# IMPORTANT: every initial *_event call below must be non-blocking, and every
# persistent listener must only spawn when its tool/hardware exists. Otherwise
# a blocking init call (e.g. bluetoothctl on a machine with no adapter) prevents
# the function from ever reaching the foreground `hc --idle` at the bottom — and
# without that idle, NO herbstclient hooks (volume_refresh, brightness_refresh,
# weather_refresh, bt_refresh) reach the panel's read loop. The visible symptom
# is: initial values show once, the clock ticks, but nothing event-driven
# updates until a full reload re-runs these initial calls.

event_generator() {
    pids=()

    # Date: the only timed loop (1s), fork-free via bash builtins.
    while true ; do
        printf "date\t^fg($color_fg_dim)%(%a)T, ^fg($color_fg)%(%d)T.%(%m.%Y)T ^fg($color_fg)%(%H:%M)T\n"
        sleep 1 || break
    done > >(uniq_linebuffered) &
    pids+=($!)

    # Initial values at login. Each guarded/non-blocking so a missing tool or
    # absent hardware cannot stall the path to `hc --idle` below.
    command -v wpctl        >/dev/null 2>&1 && volume_event
    command -v brightnessctl >/dev/null 2>&1 && brightness_event
    battery_event            # bat.sh already returns early when no BAT* exists
    weather_event            # just cats a cache file; safe if absent
    command -v bluetoothctl >/dev/null 2>&1 && bt_event   # bt_read bails if no adapter

    # Media: event-based on track/status change.
    if command -v playerctl >/dev/null 2>&1; then
        playerctl --follow metadata --format $'med\t{{artist}}\x1f{{title}}' 2>/dev/null \
            > >(uniq_linebuffered) &
        pids+=($!)
    fi

    # Bluetooth listener — only if an adapter is actually present, otherwise
    # interactive bluetoothctl can block/spin on a desktop with no radio.
    if command -v bluetoothctl >/dev/null 2>&1 \
       && bluetoothctl list 2>/dev/null | grep -q .; then
        { echo; sleep infinity; } | stdbuf -oL bluetoothctl 2>/dev/null \
            | grep --line-buffered -E 'Connected: (yes|no)|Powered: (yes|no)' \
            | while read -r _ ; do bt_event ; done > >(uniq_linebuffered) &
        pids+=($!)
    fi

    # PipeWire volume changes that bypass our keybind hooks (AVRCP, sink switch).
    if command -v pw-mon >/dev/null 2>&1; then
        stdbuf -oL pw-mon 2>/dev/null \
            | grep --line-buffered -i 'volume' \
            | while read -r _ ; do volume_event ; done > >(uniq_linebuffered) &
        pids+=($!)
    fi

    # Battery — event-based via upower, only when a battery + upower exist.
    if command -v upower >/dev/null 2>&1 && [ -n "$BATTERY" ]; then
        stdbuf -oL upower --monitor-detail 2>/dev/null \
            | grep --line-buffered -E 'percentage:|state:' \
            | while read -r _ ; do battery_event ; done > >(uniq_linebuffered) &
        pids+=($!)
    fi

    # Foreground: delivers all herbstclient hooks into the pipe. MUST be reached.
    hc --idle
    kill "${pids[@]}" 2>/dev/null
}
