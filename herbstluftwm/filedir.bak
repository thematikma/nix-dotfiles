#!/usr/bin/env bash
# lib/volume.sh - Volume logics for the panel
# We need volume_event, in case the volume is altered outside the script. The
# function is called in the event loop in panel.sh.
# volume_read provides actual values and is executed through herbstclient
# emit_hook in panel.sh (volume_refresh), so we get fresh values on change,
# no matter the event loop's position.
#
# Parsing is pure bash: wpctl prints "Volume: 0.65 [MUTED]"; we turn the
# 0.NN float into an integer percent without awk, so it is immune to the
# comma-decimal locale issue that made awk parse "0.65" as 0.

# Convert a wpctl get-volume line into vol_pct (int) + vol_muted (yes/no).
# Returns 1 on empty input. Pure bash, no subprocess, no locale dependence.
_vol_parse() {
    local raw=$1
    [ -n "$raw" ] || return 1

    local f=${raw#* }     # drop "Volume:"
    f=${f%% *}            # first token after that -> "0.65"

    local int frac
    int=${f%%.*}          # integer part, e.g. "0" or "1"
    if [[ $f == *.* ]]; then
        frac=${f#*.}      # fractional part, e.g. "65", "5", "05"
    else
        frac=""
    fi

    frac=${frac}00        # pad on the right so short fracs work ("5" -> "500")
    frac=${frac:0:2}      # keep hundredths -> "65", "50", "05"

    int=$((10#${int:-0})) # 10# guards against leading-zero octal parsing
    frac=$((10#$frac))

    vol_pct=$(( int * 100 + frac ))

    if [[ $raw == *"[MUTED]"* ]]; then
        vol_muted="yes"
    else
        vol_muted="no"
    fi
}

# Generate events
volume_event() {
    local raw
    raw=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null)
    _vol_parse "$raw" || return
    printf 'vol\t%s\t%s\n' "$vol_pct" "$vol_muted"
}

# Read and set vol_pct / vol_muted (for the volume_refresh hook)
volume_read() {
    local raw
    raw=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null)
    _vol_parse "$raw"
}

# Build dzen2 string incl. ^ca() for mouse buttons. Expects $hc_quoted,
# $color_fg, $color_fg_dim from panel.sh.
# Scroll up = louder, scroll down = quieter, left-click = mute toggle.
volume_format() {
    local ca_open ca_close
    ca_open="^ca(1,$hc_quoted spawn sh -c 'wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle; herbstclient emit_hook volume_refresh')"
    ca_open+="^ca(4,$hc_quoted spawn sh -c 'wpctl set-volume --limit 1.0 @DEFAULT_AUDIO_SINK@ 5%+; herbstclient emit_hook volume_refresh')"
    ca_open+="^ca(5,$hc_quoted spawn sh -c 'wpctl set-volume --limit 1.0 @DEFAULT_AUDIO_SINK@ 5%-; herbstclient emit_hook volume_refresh')"
    ca_close="^ca()^ca()^ca()"
    if [ "$vol_muted" = "yes" ]; then
        volume="${ca_open}^fg($color_fg_dim)vol: M ${vol_pct}%^fg()${ca_close}"
    else
        volume="${ca_open}^fg($color_fg_dim)vol: ^fg()^fg($color_fg)${vol_pct}%^fg()${ca_close}"
    fi
}
